{
  "manifest_version": 3,
  "name": "Netflix Chinese Subtitle Overlay",
  "description": "Translate Netflix subtitles into Chinese with local caching and synced playback overlay.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.netflix.com/*",
    "https://*.nflxvideo.net/*",
    "https://api.openai.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/watch/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/pageHook.js"],
      "matches": ["https://www.netflix.com/*"]
    }
  ],
  "options_page": "src/options.html",
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Netflix Chinese Subtitles",
    "default_popup": "src/options.html"
  }
}
